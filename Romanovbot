ADMIN_IDS = [1252174241]

# Список всех доступных ролей
ALL_ROLES = [
  "Татьяна Николаевна", "Мария Николаевна", "Анастасия Николаевна", 
  "Алексей Николаевич", "Григорий Распутин"
