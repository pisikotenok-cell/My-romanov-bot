DATA_FILE = "busy_roles.json"

def load_busy_roles():
  if os.path.exists(DATA_FILE):
    with open(DATA_FILE, "r", encoding="utf-8") as f:
      return json.load(f)
  return {}

def save_busy_roles(roles):
  with open(DATA_FILE, "w", encoding="utf-8") as f:
    json.dump(roles, f, ensure_ascii=False, indent=4)

busy_roles = load_busy_roles()

def get_main_menu():
  keyboard = InlineKeyboardMarkup(inline_keyboard=[])
   
  # Добавляем кнопки ролей по парам
  for i in range(0, len(ALL_ROLES), 2):
    row = []
    for j in range(2):
      if i + j < len(ALL_ROLES):
        role = ALL_ROLES[i + j]
        status = "🔴" if role in busy_roles else "🟢"
        row.append(InlineKeyboardButton(text=f"{status} {role}", callback_data=f"role_{role}"))
    keyboard.inline_keyboard.append(row)
     
  # Кнопка ссылки на флуд
  keyboard.inline_keyboard.append([
    InlineKeyboardButton(text="Ссылка на флуд ➡️", url="https://t.me/+fT90_6_S9000MGYy")
  ])
  return keyboard

@dp.message(Command("start"))
async def cmd_start(message: Message):
